[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/tools/EnemyTraceSimulatorWindow.cs" id="1_enemy_trace_window"]
[ext_resource type="Script" path="res://scripts/tools/EnemyTraceBoardView.cs" id="2_enemy_trace_board"]

[node name="EnemyTraceSimulator" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_enemy_trace_window")

[node name="Root" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 10

[node name="MainLayout" type="VBoxContainer" parent="Root"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="Title" type="Label" parent="Root/MainLayout"]
layout_mode = 2
text = "Lady Bug - Enemy trace simulator"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 22

[node name="PlaybackControls" type="HBoxContainer" parent="Root/MainLayout"]
layout_mode = 2
size_flags_horizontal = 3

[node name="SettingsButton" type="Button" parent="Root/MainLayout/PlaybackControls"]
custom_minimum_size = Vector2(58, 38)
layout_mode = 2
theme_override_font_sizes/font_size = 23
text = "⚙"
tooltip_text = "Éditer config/mame_trace_settings.json"

[node name="LaunchMameLuaButton" type="Button" parent="Root/MainLayout/PlaybackControls"]
custom_minimum_size = Vector2(150, 38)
layout_mode = 2
text = "Lancer MAME/Lua"
tooltip_text = "Lancer MAME avec le script Lua en utilisant res://config/mame_trace_settings.json"

[node name="LoadTraceButton" type="Button" parent="Root/MainLayout/PlaybackControls"]
custom_minimum_size = Vector2(120, 38)
layout_mode = 2
text = "Charger trace"
tooltip_text = "Charger la dernière trace générée, ou la trace par défaut dans res://traces/mame"

[node name="ToolbarSeparator" type="VSeparator" parent="Root/MainLayout/PlaybackControls"]
custom_minimum_size = Vector2(12, 0)
layout_mode = 2

[node name="RunSimulationButton" type="Button" parent="Root/MainLayout/PlaybackControls"]
custom_minimum_size = Vector2(58, 38)
layout_mode = 2
theme_override_font_sizes/font_size = 23
text = "↺"
tooltip_text = "Relancer la simulation depuis le début"

[node name="PauseResumeButton" type="Button" parent="Root/MainLayout/PlaybackControls"]
custom_minimum_size = Vector2(58, 38)
layout_mode = 2
theme_override_font_sizes/font_size = 23
text = "▶"
tooltip_text = "Mettre en pause ou reprendre la simulation"

[node name="StepButton" type="Button" parent="Root/MainLayout/PlaybackControls"]
custom_minimum_size = Vector2(58, 38)
layout_mode = 2
theme_override_font_sizes/font_size = 23
text = "▶|"
tooltip_text = "Avancer d’un tick"

[node name="StatusLabel" type="Label" parent="Root/MainLayout/PlaybackControls"]
layout_mode = 2
size_flags_horizontal = 3
text = "Aucune trace chargée."
horizontal_alignment = 2
vertical_alignment = 1

[node name="BoardComparison" type="HBoxContainer" parent="Root/MainLayout"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="SimulationBoard" type="Control" parent="Root/MainLayout/BoardComparison"]
custom_minimum_size = Vector2(360, 360)
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
script = ExtResource("2_enemy_trace_board")

[node name="MameTraceBoard" type="Control" parent="Root/MainLayout/BoardComparison"]
custom_minimum_size = Vector2(360, 360)
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
script = ExtResource("2_enemy_trace_board")

[node name="Console" type="TextEdit" parent="Root/MainLayout"]
custom_minimum_size = Vector2(0, 140)
layout_mode = 2
size_flags_horizontal = 3
editable = false
text = ""
